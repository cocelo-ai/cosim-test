    <motor joint="left_wheel_joint" name="left_wheel_motor" ctrllimited="true" ctrlrange="-17 17" />
    <motor joint="right_wheel_joint" name="right_wheel_motor" ctrllimited="true" ctrlrange="-17 17" />
